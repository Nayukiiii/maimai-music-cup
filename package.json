{
  "name": "maimai-music-cup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:import": "node scripts/import-assets.mjs",
    "songs:import-cn": "node scripts/import-cn-songs.mjs",
    "candidates:generate": "node scripts/generate-youtube-candidates.mjs",
    "game:scan": "node scripts/scan-game-files.mjs",
    "jp-assets:extract": "python3 scripts/extract_jp_assets.py",
    "jp-assets:thumbs": "python3 scripts/generate_jacket_thumbnails.py",
    "songs:import-jp-package": "python3 scripts/import_jp_package.py",
    "data:precompute": "node scripts/precompute-site-data.mjs",
    "deploy:prepare": "npm run data:precompute && npm run jp-assets:thumbs",
    "deploy:prewarm": "node scripts/prewarm-cloudflare.mjs",
    "release:check": "node scripts/validate-release.mjs",
    "release:check:assets": "node scripts/validate-release.mjs --require-assets",
    "dev": "vite --host 0.0.0.0",
    "build:app": "tsc -b && vite build",
    "build": "npm run data:precompute && npm run build:app",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
